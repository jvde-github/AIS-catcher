// {"author":"jvde-github","description":"add option to look up vessel details in ShipXplorer", "version": 4}

if (typeof AISCatcher !== 'undefined' && AISCatcher.PLUGIN_API_VERSION >= 4) {
    AISCatcher.addShipcardItem('search', 'ShipXplorer', 'Lookup vessel on ShipXplorer', () => {
        window.open('https://www.shipxplorer.com/data/vessels/IMO-MMSI-' + AISCatcher.card_mmsi);
    });
}
