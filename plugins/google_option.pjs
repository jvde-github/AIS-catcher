// {"author":"jvde-github","description":"add option to look up location in Google Maps", "version": 4}

if (typeof PLUGIN_API_VERSION !== 'undefined' && PLUGIN_API_VERSION >= 4) {
    addShipcardItem('search', 'Google', 'Lookup vessel coordinates on Google maps', () => {
        if (card_mmsi in shipsDB) {
            const ship = shipsDB[card_mmsi].raw;
            window.open('https://www.google.com/maps/search/?api=1&query=' + ship.lat + ',' + ship.lon);
        }
    });
}
