// {"author":"jvde-github","description":"add option to look up vessel details in VesselFinder", "version": 4}

if (typeof AISCatcher !== 'undefined' && AISCatcher.PLUGIN_API_VERSION >= 4) {
    AISCatcher.addShipcardItem('search', 'VesselFinder', 'Lookup vessel on VesselFinder', () => {
        window.open('https://www.vesselfinder.com/vessels/details/' + AISCatcher.card_mmsi);
    });
}
